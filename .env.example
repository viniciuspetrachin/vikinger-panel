SERVER_NAME='MyValheimServer'
WORLD_NAME='MyWorld'
SERVER_PASS=''
SERVER_PUBLIC='true'
SERVER_ARGS=''
MAX_PLAYERS=10
BACKUPS='true'
BACKUPS_CRON='0 * * * *'
BACKUPS_MAX_AGE='30'
BACKUPS_MAX_COUNT='0'
BACKUPS_IF_IDLE='true'
# Game updates (valheim-updater)
# UPDATE_CRON='*/15 * * * *'
# UPDATE_IF_IDLE='true'
# Leave UPDATE_CRON empty to disable auto-updates
HOST_PROJECT_DIR=/path/to/vikinger-panel
DOCKER_GID=999
PANEL_PORT=8080

# RCON (ValheimRcon) — interactive console and instant moderation in the panel
# Password is auto-generated in config/bepinex/org.tristan.rcon.cfg when modded mode is enabled.
# Use the lines below only for manual override (optional):
# PANEL_RCON_HOST=valheim
# PANEL_RCON_PORT=
# PANEL_RCON_PASSWORD=
# PANEL_RCON_TIMEOUT=15
# PANEL_RCON_TIMEOUT_SLOW=90
# PANEL_RCON_IDLE_SLOW=3

# PANEL_DEFAULT_LOCALE=en-US

# Discord webhook used only by E2E tests (Send test). Keep out of git — put the real URL in .env.
# Without this, Discord delivery e2e tests are skipped (UI-only alerts tests still run).
# DISCORD_TEST_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN

# Sponsorship and commercial licensing (optional — shown in Support the Project tab)
# Defaults are built in; override only if you fork the panel.
# PANEL_DONATION_GITHUB=https://github.com/sponsors/viniciuspetrachin/dashboard
# PANEL_COMMERCIAL_EMAIL=vr.petrachin@gmail.com
# PANEL_COMMERCIAL_URL=https://github.com/viniciuspetrachin/vikinger-panel/blob/main/COMMERCIAL-LICENSE.md
