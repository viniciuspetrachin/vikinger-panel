SERVER_NAME='MeuServidor'
WORLD_NAME='MeuMundo'
SERVER_PASS=''
SERVER_PUBLIC='true'
SERVER_ARGS=''
MAX_PLAYERS=10
BACKUPS='true'
BACKUPS_CRON='0 * * * *'
BACKUPS_MAX_AGE='30'
BACKUPS_MAX_COUNT='0'
BACKUPS_IF_IDLE='true'
# Atualizações do jogo (valheim-updater)
# UPDATE_CRON='*/15 * * * *'
# UPDATE_IF_IDLE='true'
# Deixe UPDATE_CRON vazio para desativar auto-atualização
HOST_PROJECT_DIR=/caminho/para/vikinger-panel
DOCKER_GID=999
PANEL_PORT=8080

# RCON (ValheimRcon) — console interativo e moderação instantânea no painel
# A senha é gerada automaticamente em config/bepinex/org.tristan.rcon.cfg ao ativar o modo Com mods.
# Use as linhas abaixo apenas para override (opcional):
# PANEL_RCON_HOST=valheim
# PANEL_RCON_PORT=
# PANEL_RCON_PASSWORD=
# PANEL_RCON_TIMEOUT=15
# PANEL_RCON_TIMEOUT_SLOW=90
# PANEL_RCON_IDLE_SLOW=3

# Doações e licenciamento comercial (opcional — aparecem na aba Doações)
# PANEL_DONATION_GITHUB=https://github.com/sponsors/seu-usuario
# PANEL_DONATION_KOFI=https://ko-fi.com/seu-usuario
# PANEL_DONATION_BUYMEACOFFEE=https://buymeacoffee.com/seu-usuario
# PANEL_DONATION_PIX=sua-chave-pix@email.com
# PANEL_COMMERCIAL_EMAIL=licensing@seudominio.com
# PANEL_COMMERCIAL_URL=https://github.com/viniciuspetrachin/vikinger-panel/blob/main/COMMERCIAL-LICENSE.md
